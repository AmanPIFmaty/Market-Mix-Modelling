###########################################################
# ADSTOCK FUNCTIONS
###########################################################

def geometric_adstock(x, decay, max_lag=26):
    """
    Simple exponential decay
    weight[lag] = decay^lag
    decay close to 1 = long memory
    decay close to 0 = fast decay
    """
    weights = np.array([decay**i for i in range(max_lag)])
    weights = weights / weights.sum()
    return np.convolve(x, weights, mode="full")[:len(x)]


def weibull_adstock(x, shape, scale, max_lag=26):
    """
    Flexible decay — can peak after lag 0
    shape > 1 = delayed peak effect
    shape < 1 = instant peak then slow decay
    """
    lags    = np.arange(max_lag)
    weights = weibull_min.pdf(lags + 1, c=shape, scale=scale)
    if weights.sum() == 0:
        return x
    weights = weights / weights.sum()
    return np.convolve(x, weights, mode="full")[:len(x)]


def apply_adstock(x, adstock_type, params):
    """
    Applies correct adstock based on type
    """
    if adstock_type == "geometric":
        return geometric_adstock(
            x,
            decay   = params["decay"],
            max_lag = 26
        )
    else:  # weibull
        return weibull_adstock(
            x,
            shape   = params["shape"],
            scale   = params["scale"],
            max_lag = 26
        )


def hill_transform(x, alpha, k):
    """
    Saturation curve — zero preserving
    Output always between 0 and 1
    """
    x = np.clip(x, 0, None)
    return np.where(
        x == 0,
        0,
        x**alpha / (x**alpha + k**alpha + 1e-8)
    )

###########################################################
# FEATURE BUILDER
###########################################################

def build_feature_matrix(data, media_cols, params):
    """
    For each media channel:
      1. Apply adstock (geometric or weibull)
      2. Apply Hill saturation
    Then add all control variables
    Returns complete feature matrix
    """
    features = {}

    for col in media_cols:
        if col not in data.columns:
            continue

        series = data[col].fillna(0).values

        # Get this channel's params
        adstock_type = params[f"{col}_adstock_type"]

        adstock_params = {}
        if adstock_type == "geometric":
            adstock_params["decay"] = params[f"{col}_decay"]
        else:
            adstock_params["shape"] = params[f"{col}_shape"]
            adstock_params["scale"] = params[f"{col}_scale"]

        alpha = params[f"{col}_alpha"]
        k     = params[f"{col}_k"]

        # Step 1 — Adstock
        adstocked = apply_adstock(series, adstock_type, adstock_params)

        # Step 2 — Hill saturation
        transformed = hill_transform(adstocked, alpha, k)

        features[col] = transformed

    # Add control variables
    for col in ALL_CONTROL_COLS:
        if col in data.columns:
            features[col] = data[col].fillna(0).values

    return pd.DataFrame(features)

###########################################################
# OPTUNA OBJECTIVE FUNCTION
# Searches for best adstock type + params per channel
# Optimizes ridge alpha too
# Evaluated on OOS R²
###########################################################

def build_objective(train_data, test_data, media_cols):

    def objective(trial):

        params = {}

        for col in media_cols:
            if col not in train_data.columns:
                continue

            # Let Optuna choose adstock type
            adstock_type = trial.suggest_categorical(
                f"{col}_adstock_type",
                ["geometric", "weibull"]
            )
            params[f"{col}_adstock_type"] = adstock_type

            if adstock_type == "geometric":
                params[f"{col}_decay"] = trial.suggest_float(
                    f"{col}_decay", 0.1, 0.95
                )
            else:
                params[f"{col}_shape"] = trial.suggest_float(
                    f"{col}_shape", 0.5, 5.0
                )
                params[f"{col}_scale"] = trial.suggest_float(
                    f"{col}_scale", 1.0, 15.0
                )

            # Hill parameters for all channels
            params[f"{col}_alpha"] = trial.suggest_float(
                f"{col}_alpha", 0.5, 3.0
            )
            params[f"{col}_k"] = trial.suggest_float(
                f"{col}_k", 
                # k should be within observed spend range
                train_data[col].quantile(0.1) + 1,
                train_data[col].quantile(0.9) + 1
            )

        # Ridge alpha also optimized
        ridge_alpha = trial.suggest_float(
            "ridge_alpha", 0.01, 100.0, log=True
        )

        # Build features
        X_train = build_feature_matrix(train_data, media_cols, params)
        X_test  = build_feature_matrix(test_data,  media_cols, params)

        # Align columns
        for col in X_train.columns:
            if col not in X_test.columns:
                X_test[col] = 0.0
        X_test = X_test[X_train.columns]

        # Handle any remaining nulls
        X_train = X_train.fillna(0)
        X_test  = X_test.fillna(0)

        # Scale
        scaler   = StandardScaler()
        Xs_train = scaler.fit_transform(X_train)
        Xs_test  = scaler.transform(X_test)

        y_train  = train_data["sales_amount"].fillna(0).values
        y_test   = test_data["sales_amount"].fillna(0).values

        # Ridge — positive=True enforces positive ROAS
        model = Ridge(alpha=ridge_alpha, positive=True)
        model.fit(Xs_train, y_train)

        preds = model.predict(Xs_test)
        score = r2_score(y_test, preds)

        return score

    return objective

