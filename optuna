def validate_saturation(x_transformed, col_name):
    issues = []
    if x_transformed.max() > 1.0:
        issues.append(f"max={x_transformed.max():.3f} > 1.0")
    if x_transformed.min() < 0:
        issues.append(f"min={x_transformed.min():.3f} < 0")
    nonzero = x_transformed[x_transformed > 0]
    if len(nonzero) > 5:
        p90 = np.percentile(nonzero, 90)
        p95 = np.percentile(nonzero, 95)
        if p95 / (p90 + 1e-8) > 1.5:
            issues.append(f"weak saturation p90={p90:.3f} p95={p95:.3f}")
    status = "✓ OK" if not issues else f"⚠ {issues}"
    print(f"  {col_name:40s} {status}")
    return len(issues) == 0


